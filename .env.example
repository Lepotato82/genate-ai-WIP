# Core mode
ENVIRONMENT=development
MOCK_MODE=true

# LLM routing
LLM_PROVIDER=groq
LLM_VISION_PROVIDER=anthropic
LLM_TEXT_MODEL=llama-3.2-90b-text-preview
LLM_VISION_MODEL=claude-haiku-4-5
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TEXT_MODEL=llama3.2:latest
OLLAMA_VISION_MODEL=llava:latest

# Provider keys (fill only what you use)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional integrations
TAVILY_API_KEY=
FAL_API_KEY=
BANNERBEAR_API_KEY=
BANNERBEAR_TEMPLATE_UID=
PEXELS_API_KEY=
BROWSERLESS_API_KEY=

# Data and infra
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL=
QDRANT_URL=
QDRANT_API_KEY=
REDIS_URL=

# Feature flags
RESEARCH_AUGMENTATION_ENABLED=false
KNOWLEDGE_LAYER_ENABLED=false
IMAGE_GENERATION_ENABLED=false
HERO_IMAGE_ENABLED=false
HERO_IMAGE_PROVIDER=pollinations
